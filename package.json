{
  "name": "nestjs-boilerplate-2026",
  "version": "0.0.1",
  "description": "NestJS boilerplate 2026",
  "author": "mits87",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "pnpm": ">= 10.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist && rimraf src/metadata.ts",
    "postinstall": "rimraf src/metadata.ts && dotenvx run -f .env -f .env.dist -- prisma generate",
    "typecheck": "tsc --noEmit",
    "build": "nest build",
    "prisma": "dotenvx run -f .env -f .env.dist -- prisma",
    "db:generate": "dotenvx run -f .env -f .env.dist -- prisma generate",
    "db:push": "dotenvx run -f .env -f .env.dist -- prisma db push",
    "db:pull": "dotenvx run -f .env -f .env.dist -- prisma db pull",
    "db:migrate": "dotenvx run -f .env -f .env.dist -- prisma migrate dev",
    "db:migrate:deploy": "dotenvx run -f .env -f .env.dist -- prisma migrate deploy",
    "db:seed": "dotenvx run -f .env -f .env.dist -- prisma db seed",
    "db:reset": "dotenvx run -f .env -f .env.dist -- prisma migrate reset",
    "db:studio": "dotenvx run -f .env -f .env.dist -- prisma studio",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"prisma/**/*.ts\" \"*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"prisma/**/*.ts\" \"*.ts\"",
    "lint": "eslint \"{src,test,prisma}/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"{src,test,prisma}/**/*.ts\" --max-warnings=0 --fix",
    "start:dev": "dotenvx run -f .env -f .env.dist -- nest start --watch",
    "start:debug": "dotenvx run -f .env -f .env.dist -- nest start --debug --watch",
    "start:prod": "dotenvx run -f .env -f .env.dist -- node dist/src/main.js",
    "start:repl": "dotenvx run -f .env -f .env.dist -- nest start --entryFile repl --watch",
    "start": "dotenvx run -f .env -f .env.dist -- nest start",
    "test": "vitest run --silent",
    "test:ci": "pnpm test:unit && pnpm test:e2e",
    "test:cov": "vitest run --coverage",
    "test:e2e": "dotenvx run -f .env.test -f .env.dist -- vitest run --silent --config vitest.e2e.config.ts",
    "test:unit": "vitest run --silent --config vitest.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.66.0",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "serve-favicon": "^2.5.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@suites/di.nestjs": "^3.1.0",
    "@suites/doubles.vitest": "^3.1.0",
    "@suites/unit": "^3.1.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@testcontainers/postgresql": "^11.14.0",
    "@tsconfig/node22": "^22",
    "@types/express": "^5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/serve-favicon": "^2.5.7",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.1.2"
}
